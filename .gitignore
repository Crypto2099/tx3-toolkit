# ── JetBrains IDE ────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
build/
gradle-app.setting
.gradletasknamecache

# ── IntelliJ Platform Gradle Plugin 2.x working directory ────────────────────
.intellijPlatform/

# ── trix build output (e.g. src/test/testData/trix-project/.tx3/) ────────────
# Matches the build/cache directory named `.tx3`, not `*.tx3` source files.
.tx3/

# ── GrammarKit generated sources ─────────────────────────────────────────────
# Generated by `./gradlew generateTx3Lexer generateTx3Parser`
# Do not commit — regenerate from .flex and .bnf source files
src/main/gen/

# ── Plugin distribution artifacts ────────────────────────────────────────────
*.zip
*.jar

# ── Gradle wrapper (must come after *.jar) ───────────────────────────────────
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ── Kotlin ────────────────────────────────────────────────────────────────────
*.class
*.kotlin_module

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Linux ─────────────────────────────────────────────────────────────────────
*~

# ── Environment / secrets ─────────────────────────────────────────────────────
# Plugin signing and publishing credentials — never commit these
.env
*.p12
*.pem
private_key.pem
certificate_chain.pem

# ── Test output ───────────────────────────────────────────────────────────────
test-results/
reports/